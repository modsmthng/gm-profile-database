---
/**
 * ProfileCard Component
 * Displays a profile in card format on the homepage
 */
import '@/styles/components/profile-card.css';

interface Props {
  profile: {
    name: string;
    displayName: string;
    description: string;
    author: string;
    date: string;
    complexity: string;
    tags: string[];
    picture?: string;
    slug: string;
  };
  index?: number;
}

const { profile, index = 0 } = Astro.props;

// Complexity badge styling
const complexityClass = {
  low: 'badge-success',
  mid: 'badge-warning',
  high: 'badge-error',
}[profile.complexity] || 'badge-neutral';

// Format date
const formattedDate = new Date(profile.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article
  class="card shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden"
  data-profile-name={profile.name}
  data-color-card={profile.picture ? 'true' : 'false'}
  style={`animation: cardEnter 250ms ease-out forwards; animation-delay: ${index * 50}ms; background-color: var(--card-bg-color, var(--color-base-100));`}
>
  <a href={`/gm-profile-database/profiles/${profile.slug}/`} class="block">
    <!-- Profile Image -->
    {profile.picture ? (
      <figure class="aspect-square bg-base-200">
        <img
          src={profile.picture}
          alt={profile.displayName}
          class="w-full h-full object-cover"
          data-extract-color="true"
          loading="lazy"
        />
      </figure>
    ) : (
      <figure class="aspect-square bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center shimmer">
        <div class="text-4xl font-bold text-base-content/30">
          {profile.displayName.substring(0, 2).toUpperCase()}
        </div>
      </figure>
    )}
    
    <div class="card-body flex flex-col">
      <!-- Top Content -->
      <div class="flex-grow">
        <!-- Title -->
        <h2 class="card-title text-lg">
          {profile.displayName}
        </h2>

        <!-- Complexity Badge -->
        <div class="flex flex-col gap-1 mb-2">
          <div class="flex gap-2 items-center">
            <span class="text-xs font-semibold text-base-content/70">Profile Complexity</span>
            <span class={`badge ${complexityClass} badge-sm`}>
              {profile.complexity}
            </span>
          </div>
          <span class="text-xs text-base-content/60">{formattedDate}</span>
        </div>

        <!-- Description -->
        <p class="text-sm text-base-content/80 line-clamp-3">
          {profile.description}
        </p>
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-1 mt-3">
        {profile.tags.slice(0, 3).map(tag => (
          <span class="badge badge-outline badge-sm">{tag}</span>
        ))}
        {profile.tags.length > 3 && (
          <span class="badge badge-ghost badge-sm">+{profile.tags.length - 3}</span>
        )}
      </div>

      <!-- Author -->
      <div class="card-actions justify-between items-center mt-2">
        <div class="text-xs text-base-content/60">
          by {profile.author}
        </div>
        <button class="btn btn-primary btn-sm">
          View Profile →
        </button>
      </div>
    </div>
  </a>
</article>

<script>
function extractAverageColor(imgElement, cardElement) {
  const img = new Image();
  img.crossOrigin = 'anonymous';
  img.src = imgElement.src;

  img.onload = () => {
    const canvas = document.createElement('canvas');
    canvas.width = 10;
    canvas.height = 10;
    const ctx = canvas.getContext('2d');

    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
    const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
    const data = imageData.data;

    let r = 0, g = 0, b = 0;
    for (let i = 0; i < data.length; i += 4) {
      r += data[i];
      g += data[i + 1];
      b += data[i + 2];
    }

    const pixelCount = data.length / 4;
    r = Math.round(r / pixelCount);
    g = Math.round(g / pixelCount);
    b = Math.round(b / pixelCount);

    // Calculate luminance and darken if too light
    const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;

    let finalR = r;
    let finalG = g;
    let finalB = b;

    if (luminance > 0.5) {
      // Color is too light, darken it
      const darknessFactor = 0.5;
      finalR = Math.round(r * darknessFactor);
      finalG = Math.round(g * darknessFactor);
      finalB = Math.round(b * darknessFactor);
    }

    const color = `rgb(${finalR}, ${finalG}, ${finalB})`;
    cardElement.style.setProperty('--card-bg-color', color);
  };

  img.onerror = () => console.error('Failed to load image for color extraction:', imgElement.src);
}

document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('[data-extract-color="true"]').forEach(img => {
    const card = img.closest('article[data-color-card="true"]');
    if (card) {
      if (img.complete) {
        extractAverageColor(img, card);
      } else {
        img.addEventListener('load', () => extractAverageColor(img, card));
      }
    }
  });
});
</script>
