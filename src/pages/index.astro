---
/**
 * Homepage
 * Displays all profiles with client-side filtering, sorting, and pagination
 */
import Base from '@/layouts/Base.astro';
import ProfileCard from '@/components/cards/ProfileCard.astro';
import PagefindSearch from '@/components/search/PagefindSearch.astro';
import FilterControls from '@/components/search/FilterControls.astro';
import { readdir, readFile } from 'fs/promises';
import { join } from 'path';
import '@/styles/components/home.css';

// Load all profiles
async function loadProfiles() {
  try {
    const profilesPath = join(process.cwd(), 'public', 'profiles');
    const entries = await readdir(profilesPath, { withFileTypes: true });

    const profiles = [];

    for (const entry of entries) {
      if (entry.isDirectory()) {
        try {
          const indexPath = join(profilesPath, entry.name, 'index.json');
          const indexContent = await readFile(indexPath, 'utf-8');
          const indexData = JSON.parse(indexContent);

          // Resolve relative picture paths
          if (indexData.picture && !indexData.picture.startsWith('/')) {
            indexData.picture = `/gm-profile-database/profiles/${entry.name}/${indexData.picture}`;
          }

          profiles.push({
            ...indexData,
            slug: entry.name,
          });
        } catch (error) {
          console.warn(`Failed to load profile ${entry.name}:`, error);
        }
      }
    }

    return profiles;
  } catch (error) {
    console.error('Error loading profiles:', error);
    return [];
  }
}

const allProfiles = await loadProfiles();

// Collect filter data
const allTags = [...new Set(allProfiles.flatMap(p => p.tags || []))].sort();
const allMachines = [...new Set(allProfiles.flatMap(p => p.machineCompatibility || []).filter(Boolean))].sort();

// Get initial values from URL
const initialSearch = Astro.url.searchParams.get('q') || '';
const initialTags = Astro.url.searchParams.get('tags')?.split(',').filter(Boolean) || [];
const initialComplexity = Astro.url.searchParams.get('complexity') || 'all';
const initialMachine = Astro.url.searchParams.get('machine') || 'all';
const initialSort = Astro.url.searchParams.get('sort') || 'newest';

// Profile data for client-side filtering (embedded as JSON)
const profilesJson = JSON.stringify(allProfiles);
---

<Base 
  title="Gaggimate Profile Store - Espresso Brewing Profiles"
  description="Browse and download community-created espresso brewing profiles for Gaggimate. Find the perfect pressure and flow profile for your setup."
>
  <!-- Hero Section -->
  <div class="hero bg-base-200 rounded-lg mb-4">
    <div class="hero-content text-center py-5">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold mb-2">Gaggimate Profile Store</h1>
        <p class="text-lg mb-4">
          Discover and download espresso brewing profiles created by the community.
          Pressure profiling, flow profiling, and everything in between.
        </p>
        <div class="stats shadow">
          <div class="stat">
            <div class="stat-title">Total Profiles</div>
            <div class="stat-value text-primary" id="stat-profiles" data-count={allProfiles.length}>0</div>
          </div>
          <div class="stat">
            <div class="stat-title">Categories</div>
            <div class="stat-value text-secondary" id="stat-tags" data-count={allTags.length}>0</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Search Section -->
  <div class="mb-3">
    <PagefindSearch
      placeholder="Search profiles by name, description, tags, author..."
      initialValue={initialSearch}
    />
  </div>

  <!-- Filter Controls -->
  <div class="mb-4">
    <FilterControls
      allTags={allTags}
      allMachines={allMachines}
      initialComplexity={initialComplexity}
      initialTags={initialTags}
      initialMachine={initialMachine}
      initialSort={initialSort}
    />
  </div>

  <!-- Results Count -->
  <div id="results-count" class="text-sm text-base-content/60 mb-3">
    Loading profiles...
  </div>

  <!-- Profile Grid -->
  <div class="profile-grid mb-8" id="profile-grid">
    {allProfiles.map((profile, index) => (
      <ProfileCard profile={profile} index={index} />
    ))}
  </div>

  <!-- Pagination -->
  <div id="pagination-container"></div>

  <!-- Empty State (hidden by default) -->
  <div id="empty-state" class="text-center py-16 hidden" style="animation: cardEnter 250ms ease-out forwards;">
    <div class="text-6xl mb-4">🔍</div>
    <h2 class="text-2xl font-bold mb-2">No Profiles Found</h2>
    <p class="text-base-content/60 mb-6 max-w-md mx-auto">
      No profiles match your current filters. Try adjusting your search or removing some filters.
    </p>
    <button id="empty-clear-all" class="btn btn-primary">
      Clear All Filters
    </button>
  </div>

  <!-- Embedded profile data for client-side filtering -->
  <script id="profiles-data" type="application/json" set:html={profilesJson} />

  <!-- Client-side filter engine -->
  <script is:inline>
    (function() {
      // ===== DATA =====
      const profilesDataEl = document.getElementById('profiles-data');
      const allProfiles = profilesDataEl ? JSON.parse(profilesDataEl.textContent) : [];
      
      // ===== CONSTANTS =====
      const PROFILES_PER_PAGE = 24;
      
      // ===== STATE =====
      const state = {
        search: '',
        tags: [],
        complexity: 'all',
        machine: 'all',
        sort: 'newest',
        page: 1,
        pagefindResults: null // Array of profile names from Pagefind, or null for no search
      };
      
      // ===== DOM REFS =====
      const profileGrid = document.getElementById('profile-grid');
      const resultsCount = document.getElementById('results-count');
      const paginationContainer = document.getElementById('pagination-container');
      const emptyState = document.getElementById('empty-state');
      const emptyClearAll = document.getElementById('empty-clear-all');
      
      // Filter control refs
      const tagCheckboxes = document.querySelectorAll('.tag-checkbox');
      const complexityBtns = document.querySelectorAll('.complexity-btn');
      const machineSelect = document.getElementById('machine-filter');
      const sortSelect = document.getElementById('sort-select');
      const tagCount = document.getElementById('tag-count');
      const filterChips = document.getElementById('filter-chips');
      const activeFiltersLabel = document.getElementById('active-filters-label');
      const clearAllBtn = document.getElementById('clear-all-btn');
      const searchInput = document.getElementById('search-input');
      const searchClear = document.getElementById('search-clear');
      
      // ===== INITIALIZATION =====
      function initFromUrl() {
        const params = new URLSearchParams(window.location.search);
        
        if (params.has('q')) state.search = params.get('q');
        if (params.has('tags')) state.tags = params.get('tags').split(',').filter(Boolean);
        if (params.has('complexity')) state.complexity = params.get('complexity');
        if (params.has('machine')) state.machine = params.get('machine');
        if (params.has('sort')) state.sort = params.get('sort');
        if (params.has('page')) state.page = parseInt(params.get('page')) || 1;
        
        applyStateToUI();
      }
      
      function applyStateToUI() {
        if (searchInput) searchInput.value = state.search;
        if (searchClear) searchClear.classList.toggle('hidden', !state.search);
        
        tagCheckboxes.forEach(cb => {
          cb.checked = state.tags.includes(cb.value);
        });
        updateTagCount();
        
        complexityBtns.forEach(btn => {
          const isActive = btn.dataset.complexity === state.complexity;
          btn.classList.toggle('btn-active', isActive);
          btn.setAttribute('aria-pressed', isActive);
        });
        
        if (machineSelect) machineSelect.value = state.machine;
        if (sortSelect) sortSelect.value = state.sort;
      }
      
      function updateTagCount() {
        if (tagCount) {
          if (state.tags.length > 0) {
            tagCount.textContent = state.tags.length;
            tagCount.classList.remove('hidden');
          } else {
            tagCount.classList.add('hidden');
          }
        }
      }
      
      function clearAllFilters() {
        state.search = '';
        state.tags = [];
        state.complexity = 'all';
        state.machine = 'all';
        state.sort = 'newest';
        state.page = 1;
        state.pagefindResults = null;
        
        if (searchInput) searchInput.value = '';
        if (searchClear) searchClear.classList.add('hidden');
        
        applyStateToUI();
        applyFilters();
      }
      
      // ===== FILTER LOGIC =====
      function filterProfiles() {
        let results = [...allProfiles];
        
        // If Pagefind results are available, filter to those profiles first
        if (state.pagefindResults && state.pagefindResults.length > 0) {
          results = results.filter(p => state.pagefindResults.includes(p.name));
        } else if (state.search && !state.pagefindResults) {
          // Fallback: client-side text search when Pagefind is not available
          const query = state.search.toLowerCase();
          results = results.filter(p => {
            const text = `${p.displayName || ''} ${p.name || ''} ${p.description || ''} ${p.author || ''} ${(p.tags || []).join(' ')}`.toLowerCase();
            return text.includes(query);
          });
        }
        
        if (state.tags.length > 0) {
          results = results.filter(p => 
            state.tags.some(tag => (p.tags || []).includes(tag))
          );
        }
        
        if (state.complexity !== 'all') {
          results = results.filter(p => p.complexity === state.complexity);
        }
        
        if (state.machine !== 'all') {
          results = results.filter(p => 
            (p.machineCompatibility || []).includes(state.machine)
          );
        }
        
        results = sortProfiles(results, state.sort);
        
        return results;
      }
      
      function sortProfiles(profiles, sortKey) {
        const sorted = [...profiles];
        
        switch (sortKey) {
          case 'newest':
            return sorted.sort((a, b) => new Date(b.date) - new Date(a.date));
          
          case 'alpha':
            return sorted.sort((a, b) => (a.displayName || a.name).localeCompare(b.displayName || b.name));
          
          case 'complexity': {
            const order = { low: 0, mid: 1, high: 2 };
            return sorted.sort((a, b) => (order[a.complexity] || 0) - (order[b.complexity] || 0));
          }
          
          default:
            return sorted;
        }
      }
      
      // ===== UI UPDATE =====
      function applyFilters() {
        const results = filterProfiles();
        updateUI(results);
      }
      
      function updateUI(results) {
        const totalResults = results.length;
        const totalProfiles = allProfiles.length;
        const start = (state.page - 1) * PROFILES_PER_PAGE;
        const end = Math.min(start + PROFILES_PER_PAGE, totalResults);
        const paginatedResults = results.slice(start, end);

        // Update results count with fade animation
        if (resultsCount) {
          resultsCount.style.opacity = '0.4';
          setTimeout(() => {
            if (totalResults === 0) {
              resultsCount.textContent = 'No profiles match your filters';
            } else if (totalResults === totalProfiles) {
              resultsCount.textContent = `Showing ${start + 1}-${end} of ${totalResults} profiles`;
            } else {
              resultsCount.textContent = `Showing ${start + 1}-${end} of ${totalResults} profiles (filtered from ${totalProfiles})`;
            }
            resultsCount.style.transition = 'opacity 150ms ease-out';
            resultsCount.style.opacity = '1';
          }, 75);
        }
        
        // Show/hide profile cards
        const allCards = document.querySelectorAll('.profile-grid article');
        allCards.forEach(card => card.style.display = 'none');
        
        paginatedResults.forEach(profile => {
          const card = document.querySelector(`article[data-profile-name="${profile.name}"]`);
          if (card) card.style.display = '';
        });
        
        // Update empty state
        if (emptyState) emptyState.classList.toggle('hidden', totalResults > 0);
        if (profileGrid) profileGrid.classList.toggle('hidden', totalResults === 0);

        // Highlight search terms in visible cards
        if (state.search) {
          highlightTerms(state.search);
        } else {
          clearHighlights();
        }

        // Update pagination
        updatePagination(totalResults);

        // Update active chips
        updateActiveChips();

        // Sync URL
        syncUrl();
      }
      
      function updatePagination(totalResults) {
        if (!paginationContainer) return;
        
        const totalPages = Math.ceil(totalResults / PROFILES_PER_PAGE);
        
        if (totalPages <= 1) {
          paginationContainer.innerHTML = '';
          return;
        }
        
        let html = `<div class="flex justify-center items-center gap-2 mt-8"><div class="join">`;
        
        // Previous
        html += `<button class="join-item btn btn-sm ${state.page <= 1 ? 'btn-disabled' : ''}" data-page="prev" ${state.page <= 1 ? 'disabled' : ''}>← Prev</button>`;
        
        // Page numbers
        const maxVisible = 5;
        let startPage = Math.max(1, state.page - Math.floor(maxVisible / 2));
        let endPage = Math.min(totalPages, startPage + maxVisible - 1);
        
        if (endPage - startPage < maxVisible - 1) {
          startPage = Math.max(1, endPage - maxVisible + 1);
        }
        
        if (startPage > 1) {
          html += `<button class="join-item btn btn-sm" data-page="1">1</button>`;
          if (startPage > 2) html += `<span class="join-item btn btn-sm btn-disabled">...</span>`;
        }
        
        for (let i = startPage; i <= endPage; i++) {
          html += `<button class="join-item btn btn-sm ${i === state.page ? 'btn-primary' : ''}" data-page="${i}">${i}</button>`;
        }
        
        if (endPage < totalPages) {
          if (endPage < totalPages - 1) html += `<span class="join-item btn btn-sm btn-disabled">...</span>`;
          html += `<button class="join-item btn btn-sm" data-page="${totalPages}">${totalPages}</button>`;
        }
        
        // Next
        html += `<button class="join-item btn btn-sm ${state.page >= totalPages ? 'btn-disabled' : ''}" data-page="next" ${state.page >= totalPages ? 'disabled' : ''}>Next →</button>`;
        
        html += `</div></div>`;
        
        paginationContainer.innerHTML = html;
        
        paginationContainer.querySelectorAll('button[data-page]').forEach(btn => {
          btn.addEventListener('click', () => {
            let page = btn.dataset.page;
            if (page === 'prev') page = state.page - 1;
            else if (page === 'next') page = state.page + 1;
            else page = parseInt(page);
            
            if (page && page !== state.page && page >= 1) {
              state.page = page;
              applyFilters();
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }
          });
        });
      }
      
      function updateActiveChips() {
        if (!filterChips) return;
        
        filterChips.innerHTML = '';
        const chips = [];
        
        if (state.search) {
          chips.push({ type: 'search', label: `Search: "${state.search}"`, value: state.search });
        }
        
        state.tags.forEach(tag => {
          chips.push({ type: 'tag', label: tag, value: tag });
        });
        
        if (state.complexity !== 'all') {
          chips.push({ type: 'complexity', label: state.complexity, value: state.complexity });
        }
        
        if (state.machine !== 'all') {
          chips.push({ type: 'machine', label: state.machine, value: state.machine });
        }
        
        chips.forEach(chip => {
          const chipEl = document.createElement('div');
          chipEl.className = 'inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium bg-base-200 border border-base-300 filter-chip';
          chipEl.style.animation = 'cardEnter 150ms ease-out';
          chipEl.style.transformOrigin = 'center';

          const colorClass = {
            search: 'text-primary',
            tag: 'text-secondary',
            complexity: 'text-accent',
            machine: 'text-info'
          }[chip.type];

          chipEl.innerHTML = `
            <span class="${colorClass}">${chip.label}</span>
            <button
              type="button"
              class="filter-chip-remove ml-1 p-0.5 rounded-full hover:bg-error hover:text-error-content transition-colors"
              aria-label="Remove filter"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          `;

          const removeBtn = chipEl.querySelector('.filter-chip-remove');
          removeBtn.addEventListener('click', () => {
            chipEl.style.animation = 'none';
            chipEl.style.transform = 'scale(0.85)';
            chipEl.style.opacity = '0';
            chipEl.style.transition = 'all 120ms ease-out';
            setTimeout(() => removeFilter(chip.type, chip.value), 120);
          });

          filterChips.appendChild(chipEl);
        });
        
        const hasFilters = chips.length > 0;
        if (activeFiltersLabel) activeFiltersLabel.classList.toggle('hidden', !hasFilters);
        if (clearAllBtn) clearAllBtn.classList.toggle('hidden', !hasFilters);
      }
      
      function removeFilter(type, value) {
        const searchInput = document.getElementById('search-input');
        const searchClear = document.getElementById('search-clear');
        
        switch (type) {
          case 'search':
            state.search = '';
            if (searchInput) searchInput.value = '';
            if (searchClear) searchClear.classList.add('hidden');
            break;
          case 'tag':
            state.tags = state.tags.filter(t => t !== value);
            break;
          case 'complexity':
            state.complexity = 'all';
            break;
          case 'machine':
            state.machine = 'all';
            break;
        }
        state.page = 1;
        applyStateToUI();
        applyFilters();
      }
      
      function applyStateToUI() {
        const tagCheckboxes = document.querySelectorAll('.tag-checkbox');
        const complexityBtns = document.querySelectorAll('.complexity-btn');
        const machineSelect = document.getElementById('machine-filter');
        const sortSelect = document.getElementById('sort-select');
        
        tagCheckboxes.forEach(cb => {
          cb.checked = state.tags.includes(cb.value);
        });
        updateTagCount();
        
        complexityBtns.forEach(btn => {
          const isActive = btn.dataset.complexity === state.complexity;
          btn.classList.toggle('btn-active', isActive);
          btn.setAttribute('aria-pressed', isActive);
        });
        
        if (machineSelect) machineSelect.value = state.machine;
        if (sortSelect) sortSelect.value = state.sort;
      }
      
      function updateTagCount() {
        const tagCount = document.getElementById('tag-count');
        if (tagCount) {
          if (state.tags.length > 0) {
            tagCount.textContent = state.tags.length;
            tagCount.classList.remove('hidden');
          } else {
            tagCount.classList.add('hidden');
          }
        }
      }
      
      // ===== URL SYNC =====
      function syncUrl() {
        const params = new URLSearchParams();
        
        if (state.search) params.set('q', state.search);
        if (state.tags.length > 0) params.set('tags', state.tags.join(','));
        if (state.complexity !== 'all') params.set('complexity', state.complexity);
        if (state.machine !== 'all') params.set('machine', state.machine);
        if (state.sort !== 'newest') params.set('sort', state.sort);
        if (state.page > 1) params.set('page', state.page.toString());
        
        const queryString = params.toString();
        const newUrl = queryString 
          ? `${window.location.pathname}?${queryString}`
          : window.location.pathname;
        
        window.history.replaceState({}, '', newUrl);
      }
      
      // ===== SEARCH HIGHLIGHTING =====
      function clearHighlights() {
        document.querySelectorAll('.search-highlight').forEach(mark => {
          const parent = mark.parentNode;
          parent.replaceChild(document.createTextNode(mark.textContent), mark);
          parent.normalize();
        });
      }
      
      function highlightTerms(query) {
        clearHighlights();
        if (!query) return;
        
        const terms = query.toLowerCase().split(/\s+/).filter(t => t.length > 1);
        if (terms.length === 0) return;
        
        const visibleCards = document.querySelectorAll('.profile-grid article:not([style*="none"])');
        visibleCards.forEach(card => {
          const textNodes = [];
          const walker = document.createTreeWalker(card, NodeFilter.SHOW_TEXT, null, false);
          let node;
          while ((node = walker.nextNode()) !== null) {
            if (node.parentElement?.closest?.('script, style')) continue;
            textNodes.push(node);
          }
          
          textNodes.forEach(textNode => {
            const text = textNode.textContent;
            const lowerText = text.toLowerCase();
            let hasMatch = false;
            let lastIndex = 0;
            const fragments = [];
            
            for (const term of terms) {
              const index = lowerText.indexOf(term, lastIndex);
              if (index !== -1) {
                hasMatch = true;
                if (index > lastIndex) {
                  fragments.push(document.createTextNode(text.slice(lastIndex, index)));
                }
                const mark = document.createElement('mark');
                mark.className = 'search-highlight';
                mark.textContent = text.slice(index, index + term.length);
                fragments.push(mark);
                lastIndex = index + term.length;
              }
            }
            
            if (hasMatch && lastIndex < text.length) {
              fragments.push(document.createTextNode(text.slice(lastIndex)));
            }
            
            if (hasMatch && fragments.length > 0) {
              const parent = textNode.parentNode;
              fragments.forEach(fragment => parent.insertBefore(fragment, textNode));
              parent.removeChild(textNode);
            }
          });
        });
      }
      
      // ===== EVENT BINDING =====
      function bindEvents() {
        // Tag checkboxes
        tagCheckboxes.forEach(cb => {
          cb.addEventListener('change', () => {
            state.tags = Array.from(tagCheckboxes)
              .filter(cb => cb.checked)
              .map(cb => cb.value);
            state.page = 1;
            updateTagCount();
            applyFilters();
          });
        });
        
        // Clear tags button
        document.querySelector('.clear-tags-btn')?.addEventListener('click', () => {
          state.tags = [];
          tagCheckboxes.forEach(cb => cb.checked = false);
          state.page = 1;
          updateTagCount();
          applyFilters();
        });
        
        // Complexity buttons
        complexityBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const complexity = btn.dataset.complexity;
            state.complexity = complexity;
            state.page = 1;

            complexityBtns.forEach(b => {
              b.classList.remove('btn-active');
              b.setAttribute('aria-pressed', 'false');
            });
            btn.classList.add('btn-active');
            btn.classList.add('active');
            btn.setAttribute('aria-pressed', 'true');

            // Remove pulse class after animation completes
            setTimeout(() => btn.classList.remove('active'), 200);

            applyFilters();
          });
        });
        
        // Machine select
        if (machineSelect) {
          machineSelect.addEventListener('change', () => {
            state.machine = machineSelect.value;
            state.page = 1;
            applyFilters();
          });
        }
        
        // Sort select
        if (sortSelect) {
          sortSelect.addEventListener('change', () => {
            state.sort = sortSelect.value;
            applyFilters();
          });
        }
        
        // Clear all buttons
        if (clearAllBtn) clearAllBtn.addEventListener('click', clearAllFilters);
        if (emptyClearAll) emptyClearAll.addEventListener('click', clearAllFilters);
        
        // Listen for search changes (from SearchBar or Pagefind)
        document.addEventListener('search-change', (e) => {
          const detail = e.detail || {};
          state.search = detail.query || '';
          state.page = 1;
          
          // Handle Pagefind results if available
          if (detail.pagefindResults) {
            state.pagefindResults = detail.pagefindResults;
          } else {
            state.pagefindResults = null;
          }
          
          applyFilters();
        });
      }
      
      // ===== COUNTER ANIMATION =====
      function animateCounter(element, target) {
        const duration = 400;
        const startTime = Date.now();
        const start = 0;

        const updateCounter = () => {
          const elapsed = Date.now() - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const current = Math.floor(start + (target - start) * progress);
          element.textContent = current;

          if (progress < 1) {
            requestAnimationFrame(updateCounter);
          }
        };

        updateCounter();
      }

      // ===== INIT =====
      function init() {
        initFromUrl();
        bindEvents();
        applyFilters();

        // Animate stats counters on load
        const statsProfiles = document.getElementById('stat-profiles');
        const statsTags = document.getElementById('stat-tags');

        if (statsProfiles && statsProfiles.dataset.count) {
          setTimeout(() => animateCounter(statsProfiles, parseInt(statsProfiles.dataset.count)), 200);
        }

        if (statsTags && statsTags.dataset.count) {
          setTimeout(() => animateCounter(statsTags, parseInt(statsTags.dataset.count)), 200);
        }
      }
      
      // Start when DOM is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
      
      // Expose for debugging
      window.filterSystem = { state, applyFilters, clearAllFilters };
    })();
  </script>

</Base>
