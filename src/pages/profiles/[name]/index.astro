---
/**
 * Profile Detail Page
 * Displays full profile information with chart and download options
 * Supports Pattern B (variants) and Pattern C (versions with variants)
 */
import Base from '@/layouts/Base.astro';
import ProfileChart from '@/components/charts/ProfileChart.astro';
import Badge from '@/components/ui/Badge.astro';
import { resolveDownloadPath, getFilename } from '@/utils/download';
import { readdir, readFile } from 'fs/promises';
import { join } from 'path';

// Generate static paths for all profiles
export async function getStaticPaths() {
  try {
    const profilesPath = join(process.cwd(), 'public', 'profiles');
    const entries = await readdir(profilesPath, { withFileTypes: true });
    
    const paths = [];
    
    for (const entry of entries) {
      if (entry.isDirectory()) {
        try {
          const indexPath = join(profilesPath, entry.name, 'index.json');
          const indexContent = await readFile(indexPath, 'utf-8');
          const indexData = JSON.parse(indexContent);
          
          paths.push({
            params: { name: entry.name },
            props: { 
              profile: {
                ...indexData,
                slug: entry.name,
              }
            },
          });
        } catch (error) {
          console.warn(`Failed to load profile ${entry.name}:`, error);
        }
      }
    }
    
    return paths;
  } catch (error) {
    console.error('Error generating static paths:', error);
    return [];
  }
}

const { profile } = Astro.props;

// Determine profile pattern
const hasVersions = profile.versions && profile.versions.length > 0;
const hasVariants = profile.variants && profile.variants.length > 0;
const isPatternC = hasVersions;
const isPatternB = hasVariants && !hasVersions;
const isPatternA = !hasVersions && !hasVariants;

// Get default version and variant
let defaultVersion = null;
let defaultVariant = null;
let defaultFile = profile.file;
let allVariantsForDisplay = [];

if (isPatternC) {
  // Pattern C: Versions with Variants
  defaultVersion = profile.versions[0];
  defaultVariant = defaultVersion.variants[0];
  defaultFile = defaultVariant.file;
  allVariantsForDisplay = defaultVersion.variants;
} else if (isPatternB) {
  // Pattern B: Just Variants
  defaultVariant = profile.variants[0];
  defaultFile = defaultVariant.file;
  allVariantsForDisplay = profile.variants;
} else if (isPatternA) {
  // Pattern A: Simple profile
  defaultFile = profile.file;
}

// Resolve download path
const downloadPath = resolveDownloadPath(profile, defaultVariant);

// Format date
const formattedDate = new Date(profile.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Difficulty badge variant
const difficultyVariant = {
  beginner: 'success',
  intermediate: 'warning',
  advanced: 'error',
}[profile.difficulty] || 'default';
---

<Base 
  title={`${profile.displayName} - Gaggimate Profile Store`}
  description={profile.description}
>
  <!-- Breadcrumb -->
  <div class="text-sm breadcrumbs mb-4">
    <ul>
      <li><a href="/gm-profile-database/">Home</a></li>
      <li>{profile.displayName}</li>
    </ul>
  </div>

  <!-- Profile Header -->
  <div class="card bg-base-100 shadow-lg mb-4" data-pagefind-body>
    <div class="card-body">
      <div class="flex flex-col md:flex-row justify-between items-start gap-4">
        <div class="flex-1">
          <h1 class="text-3xl font-bold mb-2" data-pagefind-meta="title">{profile.displayName}</h1>
          <p class="text-base-content/70 mb-4">{profile.description}</p>
          
          <!-- Metadata -->
          <div class="flex flex-wrap gap-3 items-center">
            <Badge variant={difficultyVariant as any} size="md" data-pagefind-filter="difficulty">
              {profile.difficulty}
            </Badge>
            
            <div class="text-sm text-base-content/60">
              by <span class="font-semibold" data-pagefind-filter="author">{profile.author}</span>
            </div>
            
            <div class="text-sm text-base-content/60">
              {formattedDate}
            </div>
          </div>
          
          <!-- Tags -->
          <div class="flex flex-wrap gap-2 mt-4">
            {profile.tags.map((tag: string) => (
              <Badge variant="outline" size="sm" data-pagefind-filter="tag">{tag}</Badge>
            ))}
          </div>
        </div>
        
        <!-- Download Button (Pattern A only) -->
        {isPatternA && (
          <div class="flex flex-col gap-2">
            <a 
              id="download-button"
              href={downloadPath}
              download
              class="btn btn-primary btn-lg"
              aria-label={`Download ${profile.displayName} profile`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Download Profile
            </a>
            
            {profile.link && (
              <a 
                href={profile.link}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-outline btn-sm"
              >
                💬 Discuss
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Selection Card (Pattern B & C) -->
  {(isPatternB || isPatternC) && (
    <div class="card bg-base-100 shadow-sm mb-4">
      <div class="card-body py-4">
        <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-end">
          <!-- Version dropdown (Pattern C only) -->
          {isPatternC && (
            <div class="flex-1 min-w-[140px]">
              <label class="label py-1">
                <span class="label-text font-medium">Version</span>
              </label>
              <select id="version-select" class="select select-bordered select-sm w-full">
                {profile.versions.map((version: any, index: number) => (
                  <option value={index} data-version-id={version.id} selected={index === 0}>
                    {version.label}
                    {version.status === 'beta' && ' (Beta)'}
                    {version.status === 'experimental' && ' (Exp)'}
                  </option>
                ))}
              </select>
            </div>
          )}

          <!-- Variant dropdown -->
          <div class={isPatternC ? 'flex-1 min-w-[140px]' : 'flex-1 min-w-[200px]'}>
            <label class="label py-1">
              <span class="label-text font-medium">Variant</span>
            </label>
            <select id="variant-select" class="select select-bordered select-sm w-full">
              {allVariantsForDisplay.map((variant: any, index: number) => (
                <option 
                  value={variant.id} 
                  data-file={variant.file}
                  data-download-path={variant.downloadPath}
                  data-dose={variant.doseRange}
                  data-ratio={variant.brewRatio}
                  data-temp={variant.tempRange}
                  data-time={variant.timeRange}
                  data-grind={variant.grindSize}
                  data-notes={variant.notes}
                  selected={index === 0}
                >
                  {variant.label}
                </option>
              ))}
            </select>
          </div>

          <!-- Download Button -->
          <a 
            id="download-button"
            href={downloadPath}
            download
            class="btn btn-primary btn-sm gap-2"
            aria-label={`Download ${profile.displayName} profile`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download
          </a>
        </div>

        <!-- Variant details inline -->
        <div id="variant-details" class="mt-4 pt-4 border-t border-base-300">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-sm">
            {defaultVariant?.doseRange && (
              <div class="bg-base-200 rounded px-2 py-1">
                <div class="text-xs opacity-60">Dose</div>
                <div class="font-medium">{defaultVariant.doseRange}</div>
              </div>
            )}
            {defaultVariant?.brewRatio && (
              <div class="bg-base-200 rounded px-2 py-1">
                <div class="text-xs opacity-60">Ratio</div>
                <div class="font-medium">{defaultVariant.brewRatio}</div>
              </div>
            )}
            {defaultVariant?.tempRange && (
              <div class="bg-base-200 rounded px-2 py-1">
                <div class="text-xs opacity-60">Temp</div>
                <div class="font-medium">{defaultVariant.tempRange}</div>
              </div>
            )}
            {defaultVariant?.timeRange && (
              <div class="bg-base-200 rounded px-2 py-1">
                <div class="text-xs opacity-60">Time</div>
                <div class="font-medium">{defaultVariant.timeRange}</div>
              </div>
            )}
          </div>
          {defaultVariant?.grindSize && (
            <div class="mt-2 text-sm">
              <span class="font-medium">Grind:</span> {defaultVariant.grindSize}
            </div>
          )}
          {defaultVariant?.notes && (
            <div class="mt-2 text-sm opacity-70">
              {defaultVariant.notes}
            </div>
          )}
        </div>
      </div>
    </div>
  )}

  <!-- Chart -->
  <div class="card bg-base-100 shadow-sm mb-4">
    <div class="card-body">
      <h2 class="card-title mb-4">Profile Visualization</h2>
      <div id="chart-wrapper">
        <ProfileChart 
          profileName={profile.slug}
          variantFile={defaultFile}
        />
      </div>
    </div>
  </div>

  <!-- Machine Compatibility -->
  {profile.machineCompatibility && profile.machineCompatibility.length > 0 && (
    <div class="card bg-base-100 shadow-sm mb-4">
      <div class="card-body">
        <h2 class="card-title mb-4">Compatible Machines</h2>
        <div class="flex flex-wrap gap-2">
          {profile.machineCompatibility.map((machine: string) => (
            <Badge variant="info" size="md" data-pagefind-filter="machine">{machine}</Badge>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- Back to profiles -->
  <div class="text-center mt-8">
    <a href="/gm-profile-database/" class="btn btn-ghost">
      ← Back to All Profiles
    </a>
  </div>

  <!-- Selection script -->
  <script define:vars={{ profile, isPatternC, isPatternB }}>
    const profileData = profile;
    const hasVersions = isPatternC;
    const hasVariants = isPatternB || isPatternC;
    
    let currentVariants = [];
    
    // Initialize current variants
    if (hasVersions) {
      currentVariants = profileData.versions[0].variants;
    } else if (hasVariants) {
      currentVariants = profileData.variants;
    }

    /**
     * Read variant data from selected option
     */
    function getVariantDataFromSelect(selectEl) {
      const option = selectEl.options[selectEl.selectedIndex];
      return {
        id: selectEl.value,
        file: option.dataset.file,
        downloadPath: option.dataset.downloadPath,
        doseRange: option.dataset.dose,
        brewRatio: option.dataset.ratio,
        tempRange: option.dataset.temp,
        timeRange: option.dataset.time,
        grindSize: option.dataset.grind,
        notes: option.dataset.notes
      };
    }
    
    /**
     * Update variant details display
     */
    function updateVariantDetails(variant) {
      const detailsContainer = document.getElementById('variant-details');
      if (!detailsContainer || !variant) return;
      
      let html = '<div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-sm">';
      
      if (variant.doseRange) {
        html += `<div class="bg-base-200 rounded px-2 py-1">
          <div class="text-xs opacity-60">Dose</div>
          <div class="font-medium">${variant.doseRange}</div>
        </div>`;
      }
      
      if (variant.brewRatio) {
        html += `<div class="bg-base-200 rounded px-2 py-1">
          <div class="text-xs opacity-60">Ratio</div>
          <div class="font-medium">${variant.brewRatio}</div>
        </div>`;
      }
      
      if (variant.tempRange) {
        html += `<div class="bg-base-200 rounded px-2 py-1">
          <div class="text-xs opacity-60">Temp</div>
          <div class="font-medium">${variant.tempRange}</div>
        </div>`;
      }
      
      if (variant.timeRange) {
        html += `<div class="bg-base-200 rounded px-2 py-1">
          <div class="text-xs opacity-60">Time</div>
          <div class="font-medium">${variant.timeRange}</div>
        </div>`;
      }
      
      html += '</div>';
      
      if (variant.grindSize) {
        html += `<div class="mt-2 text-sm"><span class="font-medium">Grind:</span> ${variant.grindSize}</div>`;
      }
      
      if (variant.notes) {
        html += `<div class="mt-2 text-sm opacity-70">${variant.notes}</div>`;
      }
      
      detailsContainer.innerHTML = html;
    }
    
    /**
     * Update chart with new variant data
     */
    function updateChart(variantFile) {
      const chartContainer = document.querySelector('.chart-container');
      if (!chartContainer || !variantFile) return;
      
      const profilePath = `/gm-profile-database/profiles/${profileData.slug}/${variantFile}`;
      chartContainer.setAttribute('data-profile-path', profilePath);
      
      if (window.reloadChart) window.reloadChart();
      else if (window.retryChart) window.retryChart();
    }
    
    /**
     * Update download button
     */
    function updateDownloadButton(variant) {
      const downloadButton = document.getElementById('download-button');
      if (!downloadButton || !variant) return;
      
      let downloadPath;
      if (variant.downloadPath) {
        downloadPath = variant.downloadPath;
      } else if (variant.file) {
        downloadPath = `/gm-profile-database/profiles/${profileData.slug}/${variant.file}`;
      } else if (profileData.downloadPath) {
        downloadPath = profileData.downloadPath;
      } else {
        downloadPath = `/gm-profile-database/profiles/${profileData.slug}/`;
      }
      
      downloadButton.setAttribute('href', downloadPath);
    }
    
    /**
     * Handle version selection change
     */
    const versionSelect = document.getElementById('version-select');
    if (versionSelect) {
      versionSelect.addEventListener('change', (e) => {
        const versionIndex = parseInt(e.target.value);
        const version = profileData.versions[versionIndex];
        
        currentVariants = version.variants;
        const variantSelect = document.getElementById('variant-select');
        
        if (variantSelect && currentVariants.length > 0) {
          // Rebuild variant options
          variantSelect.innerHTML = currentVariants.map((v, i) => 
            `<option value="${v.id}" data-file="${v.file}" data-download-path="${v.downloadPath || ''}" data-dose="${v.doseRange || ''}" data-ratio="${v.brewRatio || ''}" data-temp="${v.tempRange || ''}" data-time="${v.timeRange || ''}" data-grind="${v.grindSize || ''}" data-notes="${v.notes || ''}" ${i === 0 ? 'selected' : ''}>${v.label}</option>`
          ).join('');
          
          // Get first variant and update everything
          const firstVariant = currentVariants[0];
          updateVariantDetails(firstVariant);
          updateChart(firstVariant.file);
          updateDownloadButton(firstVariant);
        }
      });
    }
    
    /**
     * Handle variant selection change
     */
    const variantSelectEl = document.getElementById('variant-select');
    if (variantSelectEl) {
      variantSelectEl.addEventListener('change', (e) => {
        const variant = getVariantDataFromSelect(e.target);
        
        if (variant && variant.file) {
          updateVariantDetails(variant);
          updateChart(variant.file);
          updateDownloadButton(variant);
        }
      });
    }
  </script>
</Base>
